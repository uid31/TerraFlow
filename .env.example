# Your PostgreSQL connection string.
# Easiest free option: create a project at https://neon.tech or https://supabase.com
# and paste the connection string it gives you here.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:yourpassword@localhost:5432/terraflow"

# Any long random string — used to sign login session tokens.
JWT_SECRET="change-this-to-a-long-random-string"
